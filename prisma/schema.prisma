generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EMPLOYEE
  CLIENT
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum BagSize {
  MINI
  SMALL
  MEDIUM
  LARGE
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  role     UserRole

  cpf   String? @unique
  phone String?

  name String?

  addresses       Address[]
  carts           Cart[]
  orders          Order[]   @relation("UserOrders")
  completedOrders Order[]   @relation("CompletedOrders")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("users")
}

model Address {
  id         String  @id @default(uuid())
  userId     String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  zipCode    String
  country    String  @default("BR")
  isDefault  Boolean @default(false)
  label      String

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("addresses")
}

model Bag {
  id          String  @id @default(uuid())
  modelCode   String  @unique
  name        String
  description String  @db.Text
  material    String
  size        BagSize
  isPromotion Boolean @default(false)

  price          Decimal  @db.Decimal(10, 2)
  promotionPrice Decimal? @db.Decimal(10, 2)

  colors     BagColor[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bags")
}

model BagColor {
  id            String  @id @default(uuid())
  bagId         String
  colorName     String
  hexCode       String?
  stockQuantity Int     @default(0)

  bag    Bag     @relation(fields: [bagId], references: [id], onDelete: Cascade)
  images Image[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cartItems CartItem[]

  @@unique([bagId, colorName])
  @@map("bag_colors")
}

model Image {
  id           String  @id @default(uuid())
  bagColorId   String
  url          String
  altText      String?
  displayOrder Int     @default(0)

  bagColor BagColor @relation(fields: [bagColorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("images")
}

model Cart {
  id     String @id @default(uuid())
  userId String

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]
  orders Order[]

  status CartStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model CartItem {
  id         String @id @default(uuid())
  cartId     String
  bagId      String
  quantity   Int    @default(1)
  bagColorId String

  cart     Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  bag      Bag      @relation(fields: [bagId], references: [id])
  bagColor BagColor @relation(fields: [bagColorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, bagId, bagColorId])
  @@map("cart_items")
}

model Order {
  id           String      @id @default(uuid())
  userId       String
  addressId    String
  cartId       String?
  orderNumber  String      @unique
  status       OrderStatus @default(PENDING)
  trackingCode String?     @unique

  subtotal     Decimal @db.Decimal(10, 2)
  shippingCost Decimal @db.Decimal(10, 2)
  discount     Decimal @default(0) @db.Decimal(10, 2)
  totalAmount  Decimal @db.Decimal(10, 2)

  paymentMethod String?
  paymentStatus String?

  completedAt   DateTime?
  completedById String?

  user        User        @relation("UserOrders", fields: [userId], references: [id])
  address     Address     @relation(fields: [addressId], references: [id])
  cart        Cart?       @relation(fields: [cartId], references: [id])
  items       OrderItem[]
  completedBy User?       @relation("CompletedOrders", fields: [completedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  bagId         String
  quantity      Int
  selectedColor String
  unitPrice     Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bag   Bag   @relation(fields: [bagId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_items")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}
